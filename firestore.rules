rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isVerified() && request.auth.token.email == 'madesh1205@gmail.com'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Collections ---
    match /media/{mediaId} {
      allow read: if true; // Public gallery
      allow create, update, delete: if isAdmin();
    }

    match /visitRequests/{requestId} {
      // Identity Integrity & ID Poisoning Guard
      allow create: if isValidId(requestId);
      
      // Admin Access
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
